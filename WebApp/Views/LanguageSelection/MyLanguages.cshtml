@model WebApp.Models.Translator.Languages.TranslatorMyLanguagesVm
@{
    var count = Model.Selected?.Count ?? 0;
}

<div class="page-head mb-3">
    <div>
        <h2 class="page-title mb-1">@(await Translation.GetAsync(nameof(WebApp.Views.LanguageSelection.Resources.LanguageSelection.LanguageSelection_Heading_My_Languages)))</h2>
    </div>
</div>

@if (!Model.HasAny)
{
    <div class="card app-card">
        <div class="card-body p-4">
            <div class="empty-state">
                <div class="empty-icon" aria-hidden="true"><i class="bi bi-globe2"></i></div>
                <div>
                    <h5 class="mb-1">Pick the languages you know</h5>
                    <p class="text-muted mb-3">
                        This helps tailor the translator tools and improves your workflow.
                    </p>
                    <a asp-controller="LanguageSelection" asp-action="Languages" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-2"></i>@(await Translation.GetAsync(nameof(WebApp.Views.LanguageSelection.Resources.LanguageSelection.LanguageSelection_Button_Select_Languages)))
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card app-card">
        <div class="card-header app-card-header">
            <span class="badge text-bg-light border">@count @(await Translation.GetAsync(nameof(WebApp.Views.LanguageSelection.Resources.LanguageSelection.LanguageSelection_Badge_Total)))</span>
        </div>

        <div class="table-responsive app-table-wrap">
            <table class="table app-table mb-0 align-middle">
                <thead>
                <tr>
                    <th class="ps-3" style="width: 65%">@(await Translation.GetAsync(nameof(WebApp.Views.LanguageSelection.Resources.LanguageSelection.LanguageSelection_Column_Language)))</th>
                    <th style="width: 35%">@(await Translation.GetAsync(nameof(WebApp.Views.LanguageSelection.Resources.LanguageSelection.LanguageSelection_Column_Tag)))</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var lang in Model.Selected!)
                {
                    <tr>
                        <td class="ps-3">
                            <div class="fw-semibold">@lang.Name</div>
                        </td>
                        <td>
                            <span class="badge text-bg-light border font-monospace">@lang.Tag</span>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-transparent border-0 d-flex justify-content-end p-3">
            <a asp-controller="LanguageSelection" asp-action="Languages" class="btn btn-outline-primary">
                <i class="bi bi-pencil-square me-2"></i>@(await Translation.GetAsync(nameof(WebApp.Views.LanguageSelection.Resources.LanguageSelection.LanguageSelection_Button_Edit)))
            </a>
        </div>
    </div>
}