@model WebApp.Models.Admin.Translations.AdminTranslationsIndexVm
@using App.Domain.Enum
@using WebApp.Views.Admin.Resources
@using WebApp.Views.Shared.Resources


<div class="page-head mb-3">
    <div>
        <h2 class="page-title mb-1">@(await Translation.GetAsync(nameof(Admin.Admin_Heading_Live_Translations)))</h2>
    </div>

    <div class="page-actions d-flex gap-2">
        <a class="btn btn-primary"
           asp-action="Publish"
           asp-route-languageId="@Model.SelectedLanguageId">
            <i class="bi bi-pencil-square me-2"></i>
            @(await Translation.GetAsync(nameof(Admin.Admin_Button_Change_Translations)))
        </a>
    </div>
</div>

<div class="card app-card">
    <div class="card-body p-3 p-lg-4">
        <!-- Filters -->
        <form method="get" class="row g-2 align-items-end mb-3">
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />

            <div class="col-12 col-md-5 col-lg-4">
                <label class="form-label mb-1">@(await Translation.GetAsync(nameof(Admin.Admin_Text_Language)))</label>
                <select name="languageId" class="form-select">
                    @foreach (var lang in Model.LanguageOptions)
                    {
                        <option value="@lang.Id"
                                selected="@(Model.SelectedLanguageId.HasValue && Model.SelectedLanguageId.Value == lang.Id ? "selected" : null)">
                            @lang.Display
                        </option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-3 col-lg-2">
                <label class="form-label mb-1">@(await Translation.GetAsync(nameof(Admin.Admin_Text_Version)))</label>
                <input type="number"
                       class="form-control"
                       name="version"
                       min="1"
                       value="@(Model.SelectedVersion?.ToString() ?? "")"
                       placeholder="Any" />
            </div>

            <div class="col-12 col-md-4 col-lg-3">
                <label class="form-label mb-1">@(await Translation.GetAsync(nameof(Admin.Admin_Text_State)))</label>
                <select name="state" class="form-select">
                    @foreach (TranslationState st in Enum.GetValues(typeof(TranslationState)))
                    {
                        <option value="@st"
                                selected="@(Model.SelectedState.HasValue && Model.SelectedState.Value == st ? "selected" : null)">
                            @StateText(st)
                        </option>
                    }
                </select>
            </div>

            <div class="col-12 col-lg-3 d-grid d-sm-flex gap-2 justify-content-lg-end">
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-funnel me-2"></i>@(await Translation.GetAsync(nameof(WebApp.Views.Shared.Resources.Shared.Shared_Button_Filter)))
                </button>

                <a class="btn btn-outline-secondary"
                   asp-action="Index"
                   asp-route-languageId="@Model.SelectedLanguageId"
                   asp-route-page="1"
                   asp-route-pageSize="@Model.PageSize">
                    <i class="bi bi-x-circle me-2"></i>@(await Translation.GetAsync(nameof(WebApp.Views.Shared.Resources.Shared.Shared_Button_Reset)))
                </a>
            </div>
        </form>

        <!-- Table -->
        <div class="table-responsive app-table-wrap">
            <table class="table app-table align-middle mb-0">
                <thead>
                <tr>
                    <th style="width: 110px;">@(await Translation.GetAsync(nameof(Admin.Admin_Column_Language)))</th>
                    <th style="width: 340px;">@(await Translation.GetAsync(nameof(Admin.Admin_Column_Key)))</th>
                    <th>@(await Translation.GetAsync(nameof(Admin.Admin_Column_Content)))</th>
                    <th class="text-end" style="width: 90px;">@(await Translation.GetAsync(nameof(Admin.Admin_Column_Version)))</th>
                    <th style="width: 160px;">@(await Translation.GetAsync(nameof(Admin.Admin_Column_State)))</th>
                </tr>
                </thead>

                <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state py-4">
                                <div class="empty-icon" aria-hidden="true">
                                    <i class="bi bi-inboxes"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold">No live translations</div>
                                    <div class="text-muted small">Try changing filters or pick a different language.</div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model.Rows)
                    {
                        <tr>
                            <td>
                                <span class="badge text-bg-light border font-monospace">@r.LanguageTag</span>
                            </td>

                            <td>
                                <div class="fw-semibold text-truncate" title="@r.FriendlyKey">@r.FriendlyKey</div>
                                <div class="text-muted small text-truncate" title="@r.ResourceKey">@r.ResourceKey</div>
                            </td>

                            <td class="content-cell">
                                @if (string.IsNullOrWhiteSpace(r.Content))
                                {
                                    <span class="text-muted">—</span>
                                }
                                else
                                {
                                    <div class="content-preview" title="@r.Content">@r.Content</div>
                                }
                            </td>

                            <td class="text-end">
                                <span class="badge text-bg-light border font-monospace">@r.VersionNumber</span>
                            </td>

                            <td>
                                @Html.Raw(StateBadge(r.TranslationState))
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

    </div>

    <div class="card-footer bg-transparent border-0 px-3 px-lg-4 pb-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <form method="get" class="d-flex align-items-center gap-2">
                <input type="hidden" name="languageId" value="@Model.SelectedLanguageId" />
                <input type="hidden" name="version" value="@Model.SelectedVersion" />
                <input type="hidden" name="state" value="@Model.SelectedState" />
                <input type="hidden" name="page" value="1" />

                <span class="text-muted small">@(await Translation.GetAsync(nameof(WebApp.Views.Shared.Resources.Shared.Shared_Pager_Rows)))</span>
                <select name="pageSize"
                        class="form-select form-select-sm"
                        style="width: 90px;"
                        onchange="this.form.submit()">
                    @{
                        var sizes = new[] { 10, 25, 50, 100 };
                        foreach (var s in sizes)
                        {
                            <option value="@s" selected="@(Model.PageSize == s)">@s</option>
                        }
                    }
                </select>
            </form>

            <nav aria-label="Pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-languageId="@Model.SelectedLanguageId"
                           asp-route-version="@Model.SelectedVersion"
                           asp-route-state="@Model.SelectedState"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-pageSize="@Model.PageSize">
                            @(await Translation.GetAsync(nameof(WebApp.Views.Shared.Resources.Shared.Shared_Pager_Prev)))
                        </a>
                    </li>

                    <li class="page-item disabled d-none d-sm-inline">
                        <span class="page-link">
                            @(await Translation.GetAsync(nameof(WebApp.Views.Shared.Resources.Shared.Shared_Pager_Page))) @Model.Page 
                            @(await Translation.GetAsync(nameof(WebApp.Views.Shared.Resources.Shared.Shared_Pager_Of))) @Model.TotalPages
                        </span>
                    </li>

                    <li class="page-item disabled d-inline d-sm-none">
                        <span class="page-link">
                            @Model.Page/@Model.TotalPages
                        </span>
                    </li>

                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-languageId="@Model.SelectedLanguageId"
                           asp-route-version="@Model.SelectedVersion"
                           asp-route-state="@Model.SelectedState"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-pageSize="@Model.PageSize">
                            @(await Translation.GetAsync(nameof(WebApp.Views.Shared.Resources.Shared.Shared_Pager_Next)))
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@functions{
    private static string StateText(TranslationState state)
    {
        return state switch
        {
            TranslationState.Published => Shared.Shared_Translation_State_Published,
            TranslationState.WaitingReview => Shared.Shared_Translation_State_Waiting_Review,
            TranslationState.Approved => Shared.Shared_Translation_State_Approved,
            TranslationState.Rejected => Shared.Shared_Translation_State_Rejected,
            TranslationState.Inactive => Shared.Shared_Translation_State_Inactive,
            TranslationState.Depricated => Shared.Shared_Translation_State_Depricated,
            _ => state.ToString()
        };
    }

    private static string StateBadge(TranslationState state)
    {
        // Use consistent “soft” badge styles (still Bootstrap-native)
        var (cls, icon) = state switch
        {
            TranslationState.Published => ("text-bg-success", "check-circle"),
            TranslationState.WaitingReview => ("text-bg-warning", "hourglass-split"),
            TranslationState.Approved => ("text-bg-info", "check2"),
            TranslationState.Rejected => ("text-bg-danger", "x-circle"),
            TranslationState.Depricated => ("text-bg-secondary", "archive"),
            _ => ("text-bg-light", "info-circle")
        };

        var txt = StateText(state);
        // Add icon + ensure contrast on warning
        var extra = state is TranslationState.WaitingReview or TranslationState.Approved ? " text-dark" : "";
        return $"<span class=\"badge {cls}{extra}\"><i class=\"bi bi-{icon} me-1\"></i>{txt}</span>";
    }
}
